# Azure OpenAI credentials (required)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini

# Ragas evaluation uses the same Azure chat deployment as an evaluator LLM.
# If you later add embedding-based Ragas metrics, also set an embedding deployment.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small

# Database — path inside the container (volume-mounted to ./api/data/)
DATABASE_URL=sqlite:///./data/triage.db

# Amazon RDS PostgreSQL alternative. If POSTGRES_HOST and POSTGRES_PASSWORD
# are set, the API uses these values instead of DATABASE_URL.
POSTGRES_HOST=db-dev-triage-agent-ds-may.c1i4cqwu4kdd.eu-west-2.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-rds-password-here
# AWS RDS PostgreSQL example.
# Do not commit real usernames/passwords. Put the real value in api/.env only.
# Format:
# DATABASE_URL=postgresql+psycopg2://<username>:<password>@<rds-endpoint>:5432/<database_name>?sslmode=require
# Example:
# DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_ME@customerreviews.xxxxxx.us-east-1.rds.amazonaws.com:5432/customerreviews?sslmode=require

# MLflow tracking server (set to http://mlflow:5000 when running via docker-compose)
MLFLOW_TRACKING_URI=http://mlflow:5000
